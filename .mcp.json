{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "GitHub集成，用于自动化PR创建、Issue管理等"
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "source/images",
        "source/diagrams"
      ],
      "description": "文件系统访问，用于管理图片和图表文件"
    }
  },
  "notes": {
    "setup": [
      "1. 设置GitHub Token: export GITHUB_TOKEN=your_token",
      "2. GitHub Token需要repo权限",
      "3. 使用前确保已安装Node.js和npm"
    ],
    "usage": [
      "GitHub MCP可以:",
      "- 自动创建Pull Request",
      "- 管理Issues",
      "- 查看仓库信息",
      "- 自动打标签",
      "",
      "Filesystem MCP可以:",
      "- 管理图片文件",
      "- 管理Excalidraw图表",
      "- 批量处理文件"
    ]
  }
}
