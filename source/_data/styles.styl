// 系列专题样式
.site-series {
  margin-top: 30px;
  padding: 20px 15px;
  background: var(--content-bg-color);
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.site-series-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 15px;
  color: var(--text-color);
  padding-bottom: 10px;
  border-bottom: 2px solid var(--border-color);
  
  i {
    margin-right: 8px;
    color: var(--theme-color);
  }
}

.series-list {
  list-style: none !important;
  padding: 0 !important;
  margin: 0;
}

.series-item {
  margin-bottom: 10px;
  list-style: none !important;
  
  &::before {
    display: none !important;
  }
  
  a {
    display: flex;
    align-items: center;
    padding: 12px 10px;
    border-radius: 6px;
    text-decoration: none !important;
    border: 1px solid transparent !important;
    color: var(--text-color);
    transition: all 0.3s ease;
    
    &:hover {
      background: var(--hover-bg-color);
      border-color: var(--series-color) !important;
      transform: translateX(3px);
      
      .series-name {
        color: var(--series-color);
      }
      
      i {
        transform: scale(1.1);
      }
    }
  }
  
  i {
    font-size: 18px;
    width: 24px;
    margin-right: 10px;
    transition: transform 0.3s ease;
  }
  
  .series-name {
    flex: 1;
    font-weight: 500;
    font-size: 14px;
    transition: color 0.3s ease;
  }
  
  .series-count {
    font-size: 12px;
    color: var(--grey-5);
    background: var(--tag-bg-color);
    padding: 2px 8px;
    border-radius: 10px;
    font-weight: 500;
  }
}

// 每个系列的主题色
.series-item.ecommerce {
  --series-color: #ff6b6b;
  
  i {
    color: #ff6b6b;
  }
}

.series-item.system-design {
  --series-color: #4834d4;
  
  i {
    color: #4834d4;
  }
}

.series-item.fundamentals {
  --series-color: #26de81;
  
  i {
    color: #26de81;
  }
}

.series-item.ai {
  --series-color: #fd79a8;
  
  i {
    color: #fd79a8;
  }
}

// 移动端适配
+mobile() {
  .site-series {
    margin-top: 20px;
    padding: 15px 10px;
  }
  
  .series-item a {
    padding: 10px 8px;
  }
  
  .series-name {
    font-size: 13px !important;
  }
  
  .series-count {
    font-size: 11px !important;
  }
}
