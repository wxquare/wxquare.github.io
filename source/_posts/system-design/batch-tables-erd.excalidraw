    {
      "type": "text",
      "id": "sharding-benefits-content",
      "x": 1040,
      "y": 990,
      "width": 420,
      "height": 230,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "🚀 查询性能提升\n   • 单表数据量降低\n   • 索引更高效\n   • 查询扫描范围缩小\n\n🗄️ 数据管理便捷\n   • 按月归档历史数据\n   • 删除过期数据更简单\n   • 备份和恢复粒度更细\n\n📈 水平扩展能力\n   • 随时间自动扩展\n   • 避免单表瓶颈\n   • 支持海量数据增长",
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#087f5b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "sharding-benefits"
      ],
      "roundness": null,
      "seed": 1,
      "version": 2,
      "versionNonce": 774115463,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772090715314,
      "link": null,
      "locked": false,
      "lineHeight": 1.25,
      "index": "aj",
      "angle": 0,
      "frameId": null,
      "containerId": null,
      "originalText": "🚀 查询性能提升\n   • 单表数据量降低\n   • 索引更高效\n   • 查询扫描范围缩小\n\n🗄️ 数据管理便捷\n   • 按月归档历史数据\n   • 删除过期数据更简单\n   • 备份和恢复粒度更细\n\n📈 水平扩展能力\n   • 随时间自动扩展\n   • 避免单表瓶颈\n   • 支持海量数据增长",
      "autoResize": true
    },
