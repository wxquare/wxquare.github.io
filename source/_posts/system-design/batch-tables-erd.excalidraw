    {
      "type": "text",
      "id": "audit-log-fields",
      "x": 120,
      "y": 1515,
      "width": 380,
      "height": 270,
      "fontSize": 16,
      "fontFamily": 3,
      "text": "🔑 id (PK)\n🔗 task_id (FK) → listing_task\n🔗 item_id (FK) → item\n🎯 audit_type - 审核类型\n   • auto - 自动审核\n   • manual - 人工审核\n✅ audit_action - 审核动作\n   • approve - 通过\n   • reject - 拒绝\n📄 audit_reason - 审核意见\n🔧 rules_applied (JSON)\n   应用的审核规则清单\n📊 rule_results (JSON)\n   规则执行结果\n👤 auditor_id - 审核员ID\n🕐 audit_time",
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "audit-log"
      ],
      "roundness": null,
      "seed": 1,
      "version": 2,
      "versionNonce": 129059849,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772090715314,
      "link": null,
      "locked": false,
      "lineHeight": 1.25,
      "index": "aq",
      "angle": 0,
      "frameId": null,
      "containerId": null,
      "originalText": "🔑 id (PK)\n🔗 task_id (FK) → listing_task\n🔗 item_id (FK) → item\n🎯 audit_type - 审核类型\n   • auto - 自动审核\n   • manual - 人工审核\n✅ audit_action - 审核动作\n   • approve - 通过\n   • reject - 拒绝\n📄 audit_reason - 审核意见\n🔧 rules_applied (JSON)\n   应用的审核规则清单\n📊 rule_results (JSON)\n   规则执行结果\n👤 auditor_id - 审核员ID\n🕐 audit_time",
      "autoResize": true
    },
