    {
      "type": "text",
      "id": "sharding-logic",
      "x": 560,
      "y": 990,
      "width": 400,
      "height": 230,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "🔍 分表路由逻辑：\n\n// 根据时间计算表后缀\ntableSuffix := time.Now().Format(\"200601\")\ntableName := fmt.Sprintf(\n  \"listing_batch_task_tab_%s\",\n  tableSuffix\n)\n\n// 跨月查询（如统计最近3个月）\ntables := []\n  listing_batch_task_tab_202602,\n  listing_batch_task_tab_202601,\n  listing_batch_task_tab_202512\nUNION ALL查询",
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#5f3dc4",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "sharding"
      ],
      "roundness": null,
      "seed": 1,
      "version": 2,
      "versionNonce": 333821511,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772090715314,
      "link": null,
      "locked": false,
      "lineHeight": 1.25,
      "index": "af",
      "angle": 0,
      "frameId": null,
      "containerId": null,
      "originalText": "🔍 分表路由逻辑：\n\n// 根据时间计算表后缀\ntableSuffix := time.Now().Format(\"200601\")\ntableName := fmt.Sprintf(\n  \"listing_batch_task_tab_%s\",\n  tableSuffix\n)\n\n// 跨月查询（如统计最近3个月）\ntables := []\n  listing_batch_task_tab_202602,\n  listing_batch_task_tab_202601,\n  listing_batch_task_tab_202512\nUNION ALL查询",
      "autoResize": true
    },
