{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "if [[ \"$CLAUDE_FILE_PATH\" == *.md ]] && [[ \"$CLAUDE_FILE_PATH\" == */_posts/* ]]; then echo '✓ Markdown文章已更新: '$CLAUDE_FILE_PATH; fi"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git commit *)",
        "command": "./scripts/pre-commit-check.sh"
      }
    ]
  },
  "permissions": {
    "allowed": [
      "Bash(npm run *)",
      "Bash(hexo *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Read(*)",
      "Grep(*)",
      "Glob(*)"
    ]
  }
}
